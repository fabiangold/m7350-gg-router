#!/bin/sh
# GG Boot-Logo: Überschreibt Bootloader-Splash so früh wie möglich.
# Läuft bei S01, bevor oledd (S68) startet.
[ -e /dev/fb0 ] || exit 0
if [ -f /etc/gg_off.raw ]; then
    dd if=/etc/gg_off.raw of=/dev/fb0 bs=32768 count=1 2>/dev/null
else
    dd if=/dev/zero of=/dev/fb0 bs=32768 count=1 2>/dev/null
fi
exit 0
